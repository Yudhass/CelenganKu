<resources xmlns:tools="http://schemas.android.com/tools">
    <!-- Base application theme. -->
    <style name="Theme.CelenganKu" parent="Theme.MaterialComponents.Light.NoActionBar">
        <!-- Primary brand color. -->
        <item name="colorPrimary">@color/primary</item>
        <item name="colorPrimaryVariant">@color/primary_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent</item>
        <item name="colorOnSecondary">@color/white</item>
        <!-- Status bar color. -->
        <item name="android:statusBarColor">@color/primary_dark</item>
        <!-- Window background -->
        <item name="android:windowBackground">@color/background</item>
        <!-- FAB style -->
        <item name="floatingActionButtonStyle">@style/Widget.MaterialComponents.FloatingActionButton</item>
    </style>

    <!-- Toolbar style -->
    <style name="Theme.CelenganKu.Toolbar" parent="Widget.MaterialComponents.Toolbar.Primary">
        <item name="android:background">@color/primary</item>
    </style>

    <!-- Card style -->
    <style name="Widget.CelenganKu.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_bg</item>
    </style>

    <!-- Compact popup menu style (for transaction item 3-dot menu) -->
    <style name="CompactPopupMenu" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:textAppearanceLargePopupMenu">@style/CompactPopupMenuText</item>
        <item name="android:textAppearanceSmallPopupMenu">@style/CompactPopupMenuText</item>
    </style>
    <style name="CompactPopupMenuText" parent="TextAppearance.AppCompat.Menu">
        <item name="android:textSize">13sp</item>
        <item name="android:paddingTop">0dp</item>
        <item name="android:paddingBottom">0dp</item>
    </style>
</resources>

